{
	"name": "@savvy-web/pnpm-plugin-silk",
	"version": "0.10.1",
	"private": true,
	"description": "pnpm config dependency for centralized catalog management across the Silk ecosystem.",
	"keywords": ["pnpm", "pnpm-plugin", "config-dependency", "catalog", "monorepo", "silk"],
	"homepage": "https://github.com/savvy-web/pnpm-plugin-silk#readme",
	"bugs": {
		"url": "https://github.com/savvy-web/pnpm-plugin-silk/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/savvy-web/pnpm-plugin-silk.git"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@savvyweb.systems",
		"url": "https://savvyweb.systems"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"scripts": {
		"prebuild": "pnpm run generate:catalogs && pnpm run lint:fix",
		"build": "turbo run build:dev build:prod --log-order=grouped",
		"build:dev": "rslib build --config-loader native --env-mode dev",
		"build:inspect": "rslib inspect --config-loader native --env-mode npm --verbose",
		"build:prod": "rslib build --config-loader native --env-mode npm",
		"ci:build": "CI=\"true\" turbo run build:dev build:prod --log-order=grouped --output-logs=full",
		"ci:test": "CI=\"true\" vitest run --coverage",
		"ci:version": "savvy-changesets version && biome format --write .",
		"commit:check": "savvy-commit check",
		"commit:init": "savvy-commit init",
		"generate:catalogs": "node --import tsx scripts/generate-catalogs.ts",
		"lint": "biome check --max-diagnostics=none",
		"lint:fix": "biome check --write --max-diagnostics=none",
		"lint:fix:unsafe": "biome check --write --unsafe --max-diagnostics=none",
		"lint:md": "markdownlint-cli2 '**/*.{md,mdx}' --config './lib/configs/.markdownlint-cli2.jsonc'",
		"lint:md:fix": "markdownlint-cli2  --config './lib/configs/.markdownlint-cli2.jsonc' --fix",
		"prepare": "husky",
		"postprepare": "turbo run build:dev build:prod --output-logs=errors-only --log-order=grouped",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest --watch",
		"typecheck": "turbo run types:check --log-prefix=none --log-order=grouped",
		"types:check": "tsgo --noEmit"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:silk",
		"@effect/ai": "catalog:silk",
		"@effect/ai-anthropic": "catalog:silk",
		"@effect/ai-openai": "catalog:silk",
		"@effect/cli": "catalog:silk",
		"@effect/cluster": "catalog:silk",
		"@effect/experimental": "catalog:silk",
		"@effect/language-service": "catalog:silk",
		"@effect/opentelemetry": "catalog:silk",
		"@effect/platform": "catalog:silk",
		"@effect/platform-bun": "catalog:silk",
		"@effect/platform-node": "catalog:silk",
		"@effect/printer": "catalog:silk",
		"@effect/printer-ansi": "catalog:silk",
		"@effect/rpc": "catalog:silk",
		"@effect/sql": "catalog:silk",
		"@effect/sql-sqlite-node": "catalog:silk",
		"@effect/typeclass": "catalog:silk",
		"@effect/workflow": "catalog:silk",
		"@savvy-web/changesets": "^0.7.0",
		"@savvy-web/commitlint": "^0.4.3",
		"@savvy-web/lint-staged": "^0.6.3",
		"@savvy-web/rslib-builder": "^0.19.0",
		"@savvy-web/vitest": "^1.0.1",
		"@types/node": "catalog:silkPeers",
		"@typescript/native-preview": "catalog:silk",
		"effect": "catalog:silk",
		"jsonc-parser": "^3.3.1",
		"parse-gitignore": "^2.0.0",
		"tsx": "catalog:silk",
		"typescript": "catalog:silk",
		"yaml": "^2.8.3"
	},
	"packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "10.33.0",
			"onFail": "ignore"
		},
		"runtime": [
			{
				"name": "node",
				"version": "24.11.0",
				"onFail": "ignore"
			}
		]
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev",
		"linkDirectory": true,
		"targets": [
			{
				"protocol": "npm",
				"registry": "https://npm.pkg.github.com/",
				"directory": "dist/npm",
				"access": "public",
				"provenance": true
			},
			{
				"protocol": "npm",
				"registry": "https://registry.npmjs.org/",
				"directory": "dist/npm",
				"access": "public",
				"provenance": true
			}
		]
	}
}
