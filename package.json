{
	"name": "@savvy-web/pnpm-plugin-silk",
	"version": "0.14.5",
	"private": true,
	"description": "pnpm config dependency for centralized catalog management across the Silk ecosystem.",
	"keywords": ["pnpm", "pnpm-plugin", "config-dependency", "catalog", "monorepo", "silk"],
	"homepage": "https://github.com/savvy-web/pnpm-plugin-silk#readme",
	"bugs": {
		"url": "https://github.com/savvy-web/pnpm-plugin-silk/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/savvy-web/pnpm-plugin-silk.git"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@savvyweb.systems",
		"url": "https://savvyweb.systems"
	},
	"type": "module",
	"scripts": {
		"build": "turbo run build:dev build:prod --log-order=grouped --log-prefix=none",
		"build:dev": "tsdown --config-loader tsx --sourcemap --out-dir dist/dev",
		"build:prod": "tsdown --config-loader tsx --minify --out-dir dist/npm",
		"ci:build": "CI=\"true\" turbo run build:dev build:prod --log-order=grouped --output-logs=full --log-prefix=none --cache=local:",
		"ci:test": "CI=\"true\" vitest run --passWithNoTests",
		"ci:version": "savvy changeset version && biome format --write .",
		"generate:catalogs": "node --import tsx lib/scripts/run-generate.ts",
		"lint": "biome check --max-diagnostics=none",
		"lint:fix": "biome check --write --max-diagnostics=none",
		"lint:fix:unsafe": "biome check --write --unsafe --max-diagnostics=none",
		"lint:md": "markdownlint-cli2 --config './lib/configs/.markdownlint-cli2.jsonc'",
		"lint:md:fix": "markdownlint-cli2  --config './lib/configs/.markdownlint-cli2.jsonc' --fix",
		"prepare": "husky",
		"test": "vitest run --passWithNoTests",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest --watch",
		"typecheck": "turbo run types:check --log-prefix=none --log-order=grouped",
		"types:check": "tsgo --noEmit"
	},
	"devDependencies": {
		"@effect/ai": "catalog:silk",
		"@effect/ai-amazon-bedrock": "catalog:silk",
		"@effect/ai-anthropic": "catalog:silk",
		"@effect/ai-google": "catalog:silk",
		"@effect/ai-openai": "catalog:silk",
		"@effect/cli": "catalog:silk",
		"@effect/cluster": "catalog:silk",
		"@effect/experimental": "catalog:silk",
		"@effect/language-service": "catalog:silk",
		"@effect/opentelemetry": "catalog:silk",
		"@effect/platform": "catalog:silk",
		"@effect/platform-bun": "catalog:silk",
		"@effect/platform-node": "catalog:silk",
		"@effect/printer": "catalog:silk",
		"@effect/printer-ansi": "catalog:silk",
		"@effect/rpc": "catalog:silk",
		"@effect/sql": "catalog:silk",
		"@effect/sql-clickhouse": "catalog:silk",
		"@effect/sql-d1": "catalog:silk",
		"@effect/sql-drizzle": "catalog:silk",
		"@effect/sql-kysely": "catalog:silk",
		"@effect/sql-libsql": "catalog:silk",
		"@effect/sql-mssql": "catalog:silk",
		"@effect/sql-mysql2": "catalog:silk",
		"@effect/sql-pg": "catalog:silk",
		"@effect/sql-sqlite-bun": "catalog:silk",
		"@effect/sql-sqlite-do": "catalog:silk",
		"@effect/sql-sqlite-node": "catalog:silk",
		"@effect/sql-sqlite-react-native": "catalog:silk",
		"@effect/sql-sqlite-wasm": "catalog:silk",
		"@effect/tsgo": "catalog:silk",
		"@effect/typeclass": "catalog:silk",
		"@effect/vitest": "catalog:silk",
		"@effect/workflow": "catalog:silk",
		"@savvy-web/silk": "^0.3.1",
		"@savvy-web/vitest": "^1.4.0",
		"@types/node": "catalog:silk",
		"@types/react": "catalog:silk",
		"@types/react-dom": "catalog:silk",
		"@typescript/native-preview": "catalog:silk",
		"effect": "catalog:silk",
		"react": "catalog:silk",
		"react-dom": "catalog:silk",
		"tsdown": "^0.22.2",
		"tsx": "catalog:silk",
		"typescript": "catalog:silk",
		"yaml": "^2.9.0"
	},
	"packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485",
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485",
			"onFail": "ignore"
		},
		"runtime": [
			{
				"name": "node",
				"version": "26.3.0",
				"onFail": "ignore"
			}
		]
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev",
		"linkDirectory": true,
		"targets": [
			{
				"protocol": "npm",
				"registry": "https://npm.pkg.github.com/",
				"directory": "dist/npm",
				"access": "public",
				"provenance": true
			},
			{
				"protocol": "npm",
				"registry": "https://registry.npmjs.org/",
				"directory": "dist/npm",
				"access": "public",
				"provenance": true
			}
		]
	}
}
